generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model AdmUser {
  id     Int    @id @default(autoincrement())
  login  String @unique @db.VarChar(100)
  pass   String @db.VarChar(255)
  status String @default("administrator") @db.VarChar(50)

  @@map("adm_users")
}

model AdmLoginFail {
  id    Int      @id @default(autoincrement())
  ip    String   @db.VarChar(50)
  times Int      @default(1)
  data  DateTime @default(now())

  @@map("adm_login_fails")
}

model Lang {
  id         Int     @id @default(autoincrement())
  code       String  @unique @db.VarChar(10)
  title      String  @db.VarChar(100)
  active     Int     @default(1)
  visibility Int     @default(1)
  priority   Int     @default(0)
  flag       String? @db.VarChar(50)

  @@map("langs")
}

model Currency {
  id      Int    @id @default(autoincrement())
  title   String @db.VarChar(50)
  rate    Float  @default(1)
  uri     String @db.VarChar(20)
  enabled Int    @default(1)

  @@map("currency")
}

model Setting {
  id    Int    @id @default(autoincrement())
  value String @db.VarChar(100)
  text  String @db.Text
  lang  String @db.VarChar(10)

  @@unique([value, lang])
  @@map("settings")
}

model SettingText {
  id    Int    @id @default(autoincrement())
  value String @db.VarChar(100)
  text  String @db.Text
  lang  String @db.VarChar(10)

  @@unique([value, lang])
  @@map("settings_text")
}

model CustomString {
  id    Int    @id @default(autoincrement())
  value String @db.VarChar(100)
  text  String @db.Text
  lang  String @db.VarChar(10)

  @@unique([value, lang])
  @@map("custom_strings")
}

model Social {
  id       Int     @id @default(autoincrement())
  icon     String? @db.VarChar(50)
  title    String? @db.VarChar(100)
  text     String? @db.VarChar(500)
  priority Int     @default(0)
  enabled  Int     @default(1)

  @@map("socials")
}

model Core {
  id       Int     @id @default(autoincrement())
  uri      String  @db.VarChar(100)
  lang     String  @db.VarChar(10)
  heading  String? @db.VarChar(255)
  text     String? @db.Text
  text2    String? @db.Text
  seoTitle String? @db.VarChar(255) @map("seo_title")
  seoKey   String? @db.VarChar(500) @map("seo_key")
  seoDescr String? @db.VarChar(500) @map("seo_descr")

  @@unique([uri, lang])
  @@map("core")
}

model Measure {
  id            Int     @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String  @db.VarChar(10)
  title         String  @db.VarChar(100)
  short_title   String  @db.VarChar(50)
  priority      Int     @default(0)

  @@map("measures")
}

model MeasureReal {
  id            Int    @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String @db.VarChar(10)
  title         String @db.VarChar(100)
  short_title   String @db.VarChar(50)
  priority      Int    @default(0)

  @@map("measures_real")
}

model Category {
  id            Int     @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String  @db.VarChar(10)
  pid           Int     @default(0)
  title         String  @db.VarChar(255)
  uri           String  @db.VarChar(255)
  img           String? @db.VarChar(255)
  img2          String? @db.VarChar(255)
  discount      Float?
  ndiscount     Int?
  visibility    Int     @default(1)
  priority      Int     @default(0)
  descr         String? @db.Text
  text          String? @db.Text
  seoTitle      String? @db.VarChar(255) @map("seo_title")
  seoKey        String? @db.Text        @map("seo_key")
  seoDescr      String? @db.Text        @map("seo_descr")

  productLinks  ProductCategory[]
  filterItems   AllFilterItem[]

  @@map("categories")
}

model Product {
  id            Int     @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String  @db.VarChar(10)
  pcode         String? @db.VarChar(100)
  title         String  @db.VarChar(255)
  main_title    String? @db.VarChar(255)
  descr         String? @db.Text
  heading       String? @db.VarChar(255)
  text          String? @db.Text
  price         Float   @default(0)
  price_sale    Float?
  price2        Float?
  price3        Float?
  price2n       Float?
  price3n       Float?
  img           String? @db.VarChar(255)
  img2          String? @db.VarChar(255)
  measure       Int?
  minquantity   Float   @default(1)
  package       Int?
  uri           String  @db.VarChar(255)
  active        Int     @default(1)
  labelAction   Int     @default(0)  @map("label_action")
  popular       Int     @default(0)
  priority      Int     @default(0)
  pid           Int     @default(0)
  filterId      Int?               @map("filter_id")
  seoTitle      String? @db.VarChar(255) @map("seo_title")
  seoKey        String? @db.VarChar(500) @map("seo_key")
  seoDescr      String? @db.VarChar(500) @map("seo_descr")

  groupId       Int?               @map("group_id")

  categories    ProductCategory[]
  photos        ProductPhoto[]
  photos2       ProductPhoto2[]
  chars         ProductChar[]
  colors        ProductColor[]      @relation("ColorMain")
  colorsWith    ProductColor[]      @relation("ColorWith")
  together      ProductTogether[]   @relation("TogetherMain")
  togetherWith  ProductTogether[]   @relation("TogetherWith")
  cartItems     Cart[]
  favourites    ProductFavourite[]
  inventory     Inventory[]
  group         ProductGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@map("products")
}

model ProductCategory {
  id         Int      @id @default(autoincrement())
  pid        Int
  cid        Int

  product    Product  @relation(fields: [pid], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [cid], references: [id], onDelete: Cascade)

  @@unique([pid, cid])
  @@map("products_categories")
}

model ProductPhoto {
  id       Int     @id @default(autoincrement())
  pid      Int
  img      String  @db.VarChar(255)
  priority Int     @default(0)

  product  Product @relation(fields: [pid], references: [id], onDelete: Cascade)

  @@map("products_photos")
}

model ProductPhoto2 {
  id       Int     @id @default(autoincrement())
  pid      Int
  img      String  @db.VarChar(255)
  priority Int     @default(0)

  product  Product @relation(fields: [pid], references: [id], onDelete: Cascade)

  @@map("products_photos2")
}

model ProductChar {
  id       Int     @id @default(autoincrement())
  pid      Int
  chid     Int?
  title    String  @db.VarChar(255)
  value    String? @db.VarChar(500)
  lang     String  @db.VarChar(10)
  priority Int     @default(0)

  product  Product @relation(fields: [pid], references: [id], onDelete: Cascade)

  @@map("products_chars")
}

model ProductColor {
  id       Int     @id @default(autoincrement())
  pid      Int
  pid_with Int

  product     Product @relation("ColorMain", fields: [pid], references: [id], onDelete: Cascade)
  productWith Product @relation("ColorWith", fields: [pid_with], references: [id], onDelete: Cascade)

  @@map("products_colors")
}

model ProductTogether {
  id       Int     @id @default(autoincrement())
  pid      Int
  pid_with Int

  product     Product @relation("TogetherMain", fields: [pid], references: [id], onDelete: Cascade)
  productWith Product @relation("TogetherWith", fields: [pid_with], references: [id], onDelete: Cascade)

  @@map("products_together")
}

model ProductFavourite {
  id      Int     @id @default(autoincrement())
  pid     Int
  login   String  @db.VarChar(100)

  product Product @relation(fields: [pid], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [login], references: [login])

  @@map("products_favourites")
}

model AllFilter {
  id            Int               @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String            @db.VarChar(10)
  pid           Int               @default(0)
  uri           String?           @db.VarChar(255)
  title         String            @db.VarChar(255)
  priority      Int               @default(0)
  descr         String?           @db.Text
  img           String?           @db.VarChar(255)

  filters       AllFilterFilter[]

  @@map("all_filters")
}

model AllFilterFilter {
  id            Int             @id @default(autoincrement())
  translationId Int     @map("translation_id")
  pid           Int
  lang          String          @db.VarChar(10)
  title         String          @db.VarChar(255)
  uri           String?         @db.VarChar(100)
  priority      Int             @default(0)

  parent        AllFilter       @relation(fields: [pid], references: [id], onDelete: Cascade)
  items         AllFilterItem[]

  @@map("all_filters_filters")
}

model AllFilterItem {
  id      Int             @id @default(autoincrement())
  cid     Int             @map("cid")
  fid     Int

  category Category        @relation(fields: [cid], references: [id], onDelete: Cascade)
  filter   AllFilterFilter @relation(fields: [fid], references: [id], onDelete: Cascade)

  @@unique([cid, fid])
  @@map("all_filters_items")
}

model Slider {
  id            Int     @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String  @db.VarChar(10)
  img           String? @db.VarChar(255)
  img2          String? @db.VarChar(255)
  title         String? @db.VarChar(255)
  descr         String? @db.Text
  uri           String? @db.VarChar(500)
  priority      Int     @default(0)
  active        Int     @default(1)

  @@map("slider")
}

// Articles ("Статті") shown on /articles and /articles/{uri} on both PHP sites.
// One row per language per article — rows are NOT linked by translationId having
// a matching counterpart row in every language; many legacy articles (ru-only or
// uk-only) have no translation at all, which is expected (articles.php falls back
// to an empty string when a translation is missing, see articles.php ~line 30).
model Article {
  id            Int       @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String    @db.VarChar(10)
  uri           String    @db.VarChar(255)
  title         String    @db.VarChar(255)
  // Page <h1> on the article detail page (articles.php falls back to `heading`
  // when `heading_contact`/SEOform's `core` override isn't set). Not editable in
  // older CRM UIs — make sure it's filled in when adding a new article.
  heading       String?   @db.VarChar(255)
  descr         String?   @db.Text
  text          String?   @db.Text
  // Full R2 URL (e.g. https://pub-<hash>.r2.dev/articles/<file>.jpg), not a bare
  // filename — CRM UI must render `img` directly as the <img src>.
  img           String?   @db.VarChar(255)
  // Legacy/secondary image column — not read by either PHP site's articles.php or
  // news.php templates. Present in the DB for historical reasons only.
  img2          String?   @db.VarChar(255)
  // Legacy column, not referenced by the PHP frontend for articles (unlike
  // products/categories, where `pid` is a real parent-category FK). Safe to
  // ignore; kept only for schema parity with the live table.
  pid           Int?      @default(0)
  priority      Int       @default(0)
  data          DateTime  @default(now())
  seoTitle      String?   @db.VarChar(255) @map("seo_title")
  seoKey        String?   @db.VarChar(500) @map("seo_key")
  seoDescr      String?   @db.VarChar(500) @map("seo_descr")
  // Legacy column, not read by SEOform() or articles.php — SEO override text
  // actually comes from the `core` table (see includes/functions.php SEOform()).
  seoText       String?   @db.Text @map("seo_text")

  photos        ArticlePhoto[]

  @@map("articles")
}

model ArticlePhoto {
  id            Int     @id @default(autoincrement())
  pid           Int
  img           String  @db.VarChar(255)
  priority      Int     @default(0)
  translationId Int?    @map("translation_id")
  lang          String? @db.VarChar(10)
  title         String? @db.VarChar(255)

  article       Article @relation(fields: [pid], references: [id], onDelete: Cascade)

  @@map("articles_photos")
}

model News {
  id            Int       @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String    @db.VarChar(10)
  uri           String    @db.VarChar(255)
  title         String    @db.VarChar(255)
  descr         String?   @db.Text
  text          String?   @db.Text
  img           String?   @db.VarChar(255)
  priority      Int       @default(0)
  data          DateTime  @default(now())

  photos        NewsPhoto[]

  @@map("news")
}

model NewsPhoto {
  id       Int    @id @default(autoincrement())
  pid      Int
  img      String @db.VarChar(255)
  priority Int    @default(0)

  news     News   @relation(fields: [pid], references: [id], onDelete: Cascade)

  @@map("news_photos")
}

model Service {
  id            Int     @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String  @db.VarChar(10)
  img           String? @db.VarChar(100)
  title         String  @db.VarChar(255)
  descr         String? @db.Text
  priority      Int     @default(0)

  @@map("services")
}

model Manager {
  id            Int     @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String  @db.VarChar(10)
  img           String? @db.VarChar(255)
  title         String  @db.VarChar(255)
  descr         String? @db.Text
  phone         String? @db.VarChar(100)
  email         String? @db.VarChar(100)
  skype         String? @db.VarChar(100)
  priority      Int     @default(0)

  @@map("managers")
}

model Gallery {
  id            Int     @id @default(autoincrement())
  translationId Int     @map("translation_id")
  lang          String  @db.VarChar(10)
  img           String? @db.VarChar(255)
  title         String? @db.VarChar(255)
  uri           String? @db.VarChar(255)

  @@map("gallery")
}

model User {
  id           Int     @id @default(autoincrement())
  login        String  @unique @db.Char(50)
  password     String  @db.VarChar(255)
  rank         Int?    @db.SmallInt
  addrDelivery String? @db.Text @map("addr_delivery")
  phone        String? @db.Char(30)
  person       String? @db.Char(40)

  carts        Cart[]
  favourites   ProductFavourite[]

  @@map("users")
}

model UserCategory {
  id             Int    @id @default(autoincrement())
  translationId  Int     @map("translation_id")
  lang           String @db.VarChar(10)
  title          String @db.VarChar(255)
  discount       Float  @default(0)
  discount_total Float  @default(0)
  priority       Int    @default(0)

  @@map("users_categories")
}

model UserRecoverPassword {
  id      Int      @id @default(autoincrement())
  login   String   @db.VarChar(100)
  token   String   @db.VarChar(255)
  created DateTime @default(now())

  @@map("users_recover_password")
}

model Cart {
  id       Int      @id @default(autoincrement())
  login    String   @db.VarChar(100)
  product  Int
  type     String   @default("prod") @db.VarChar(20)
  price    Float    @default(0)
  quantity Float    @default(1)
  add_time DateTime @default(now())
  reminded Int      @default(0)

  user       User?   @relation(fields: [login], references: [login])
  productRel Product @relation(fields: [product], references: [id])

  @@map("cart")
}

model Order {
  id           Int      @id @default(autoincrement())
  login        String?  @db.Char(50)
  person       String?  @db.Char(150)
  phone        String?  @db.Char(25)
  addrDelivery String?  @db.Text @map("addr_delivery")
  status       String?  @db.Char(30)
  date         DateTime @default(now())
  notes        String?  @db.Text
  currency     String?  @db.VarChar(10)
  pay_method   String?  @db.Char(40)
  ttn          String?  @db.Char(50)
  msg          String?  @db.Text
  callme       Int?     @default(0)

  items        OrderItem[]
  returns      OrderReturn[]

  @@map("orders")
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  oid        Int
  type       String? @db.Char(15)
  product    Int
  price      Float   @default(0)
  quantity   Int     @default(1)
  price_base Float   @default(0)

  order      Order   @relation(fields: [oid], references: [id], onDelete: Cascade)

  @@map("orders_item")
}

model OrderReturn {
  id           Int        @id @default(autoincrement())
  date         DateTime   @default(now())
  login        String?    @db.VarChar(50)
  person       String?    @db.VarChar(40)
  phone        String?    @db.VarChar(15)
  reason       String?    @db.Text
  status       String?    @db.VarChar(20)
  notes        String?    @db.Text
  title        String?    @db.VarChar(255)
  quantity     String?    @db.VarChar(255)

  // Legacy storefront-submitted fields (real rows go back to 2019 — the
  // store's own return form writes these directly, not the oid/product/qty
  // fields below).
  addrDelivery String?    @db.Text @map("addr_delivery")
  legacyOrder  Int?       @map("order")
  dateOrder    String?    @db.VarChar(50) @map("date_order")
  code         String?    @db.VarChar(50)
  photo        String?    @db.VarChar(100)
  submit       String?    @db.VarChar(50)

  // Added for proper product/warehouse linkage and the status workflow
  // (legacy rows leave these null — see docs for the returns feature).
  oid          Int?
  product      Int?
  warehouseId  Int?       @map("warehouse_id")
  qty          Int?
  restocked    Boolean    @default(false)

  // Return-shipment tracking (customer ships the item back via Nova Poshta)
  // and refund bookkeeping — distinct from Order.ttn, which tracks the
  // original outgoing delivery. Set once a manager confirms the return and
  // gets the customer's tracking number; polled by the same
  // sync-ttn-status cron used for outgoing orders (see lib/nova-poshta.ts).
  ttn          String?    @db.VarChar(50)
  refunded     Boolean    @default(false)
  refundedAt   DateTime?  @map("refunded_at")

  order        Order?     @relation(fields: [oid], references: [id], onDelete: SetNull)
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@map("orders_returns")
}

model InventoryHistory {
  id              Int      @id @default(autoincrement())
  productId       Int      @map("product_id")
  warehouseId     Int      @map("warehouse_id")
  quantityBefore  Decimal  @db.Decimal(10, 2) @map("quantity_before")
  quantityAfter   Decimal  @db.Decimal(10, 2) @map("quantity_after")
  delta           Decimal  @db.Decimal(10, 2)
  source          String   @db.VarChar(30)
  changedBy       String?  @db.VarChar(100) @map("changed_by")
  note            String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("inventory_history")
}

model Doc {
  id       Int    @id @default(autoincrement())
  title    String @db.VarChar(255)
  file     String @db.VarChar(255)
  lang     String @db.VarChar(10)
  priority Int    @default(0)

  @@map("docs")
}

model Warehouse {
  id        Int         @id @default(autoincrement())
  title     String      @db.VarChar(255)
  address   String?     @db.Text
  priority  Int         @default(0)
  active    Int         @default(1)
  createdAt DateTime    @default(now()) @map("created_at")

  inventory Inventory[]
  returns   OrderReturn[]
  history   InventoryHistory[]

  @@map("warehouses")
}

model Inventory {
  id              Int       @id @default(autoincrement())
  productId       Int       @map("product_id")
  warehouseId     Int       @map("warehouse_id")
  quantity        Decimal   @default(0) @db.Decimal(10, 2)
  reserved        Decimal   @default(0) @db.Decimal(10, 2)
  initialQuantity Decimal   @default(0) @db.Decimal(10, 2) @map("initial_quantity")
  minQuantity     Decimal   @default(0) @db.Decimal(10, 2) @map("min_quantity")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@map("inventory")
}

model ProductGroup {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at")

  products  Product[]

  @@map("product_groups")
}
